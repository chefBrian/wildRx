rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /medications/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /species/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /dosingRules/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
